{
    "manifest_version": 3,
    "name": "Fantasy Tool",
    "version": "0.1.0",
    "description": "Adds points-per-budget standings and related mini-league insights to fantasy.allsvenskan.se.",
    "icons": {
        "16": "assets/icons/icon16.png",
        "32": "assets/icons/icon32.png",
        "48": "assets/icons/icon48.png",
        "128": "assets/icons/icon128.png"
    },
    "permissions": [
        "storage"
    ],
    "host_permissions": [
        "https://fantasy.allsvenskan.se/*"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "https://fantasy.allsvenskan.se/*"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_idle"
        }
    ]
}